# Copy this file to .env.local for real credentials. Keep the tracked .env blank.

# govinfo public API. Required for package and collection metadata.
GOVINFO_API_KEY=

# CourtListener REST API token. Used for opinions, dockets, and RECAP-backed examples.
COURTLISTENER_API_TOKEN=

# Congress.gov API key from api.data.gov.
CONGRESS_API_KEY=

# Open States v3 API key. Used for state-law and state-court expansion data.
OPENSTATES_API_KEY=

# Direct PACER access is intentionally optional because it can require account credentials and may incur fees.
PACER_USERNAME=
PACER_PASSWORD=

# Where generated source metadata and optional live probe results are written.
LEGAL_SOURCE_CACHE_DIR=data/legal-sources
